<Bindings>
    <Binding name="ONEWOW_DIRECTDEPOSIT_TOGGLE" category="BINDING_HEADER_ONEWOW_DIRECTDEPOSIT">
        if OneWoW_DirectDeposit and OneWoW_DirectDeposit.GUI then
            OneWoW_DirectDeposit.GUI:Toggle()
        end
    </Binding>
    <Binding name="ONEWOW_DIRECTDEPOSIT_DEPOSIT" category="BINDING_HEADER_ONEWOW_DIRECTDEPOSIT">
        if OneWoW_DirectDeposit and OneWoW_DirectDeposit.DirectDeposit then
            OneWoW_DirectDeposit.DirectDeposit:ManualDeposit()
        end
    </Binding>
    <Binding name="ONEWOW_DIRECTDEPOSIT_ADD_PERSONAL" category="BINDING_HEADER_ONEWOW_DIRECTDEPOSIT">
        if OneWoW_DirectDeposit then
            OneWoW_DirectDeposit:AddHoveredItemToList("personal")
        end
    </Binding>
    <Binding name="ONEWOW_DIRECTDEPOSIT_ADD_WARBAND" category="BINDING_HEADER_ONEWOW_DIRECTDEPOSIT">
        if OneWoW_DirectDeposit then
            OneWoW_DirectDeposit:AddHoveredItemToList("warband")
        end
    </Binding>
    <Binding name="ONEWOW_DIRECTDEPOSIT_ADD_GUILD" category="BINDING_HEADER_ONEWOW_DIRECTDEPOSIT">
        if OneWoW_DirectDeposit then
            OneWoW_DirectDeposit:AddHoveredItemToList("guild")
        end
    </Binding>
</Bindings>
